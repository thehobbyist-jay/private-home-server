{
  "name": "linux-server",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "prepare": "husky",
    "secrets:scan": "docker run --rm -v \"$PWD:/repo\" -w /repo zricethezav/gitleaks:latest git --redact --verbose .",
    "secrets:scan:staged": "docker run --rm -v \"$PWD:/repo\" -w /repo zricethezav/gitleaks:latest git --pre-commit --staged --redact --verbose"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
