    {
      "id": "7-qy8H31wE-Ko5IMxivXO",
      "type": "text",
      "x": -1271.6202756999924,
      "y": -293.2726023259678,
      "width": 1065.6875,
      "height": 357.5,
      "text": "PHASE 1: UBUNTU OS\n1. Download Ubuntu Server LTS\n2. Flash ISO using Rufus / Etcher\n3. Boot USB & install OS\n4. Enable 'OpenSSH Server'\n\nPHASE 2: INSTALL DOCKER\nRun these commands in terminal:\n\n# 1. Clean old tools\nsudo apt-get update\nsudo apt-get install ca-certificates curl gnupg -y\n\n# 2. Add Key & Repo\nsudo install -m 0755 -d /etc/apt/keyrings\ncurl -fsSL https://docker.com | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg\n\necho \"deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://docker.com $(lsb_release -cs) stable\" | sudo tee /etc/apt/sources.list.d/docker.list\n\n# 3. Install Engine\nsudo apt-get update\nsudo apt-get install docker-ce docker-ce-cli containerd.io docker-compose-plugin -y\n\n# 4. Fix Port 53 conflict\nsudo systemctl stop systemd-resolved\nsudo systemctl disable systemd-resolved",
      "fontSize": 11,
      "fontFamily": 8,
      "color": "#333333",
      "version": 8,
      "versionNonce": 304802659,
      "index": "aR",
      "isDeleted": true,
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "seed": 741446969,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "boundElements": [],
      "updated": 1782634238335,
      "link": null,
      "locked": false,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "PHASE 1: UBUNTU OS\n1. Download Ubuntu Server LTS\n2. Flash ISO using Rufus / Etcher\n3. Boot USB & install OS\n4. Enable 'OpenSSH Server'\n\nPHASE 2: INSTALL DOCKER\nRun these commands in terminal:\n\n# 1. Clean old tools\nsudo apt-get update\nsudo apt-get install ca-certificates curl gnupg -y\n\n# 2. Add Key & Repo\nsudo install -m 0755 -d /etc/apt/keyrings\ncurl -fsSL https://docker.com | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg\n\necho \"deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://docker.com $(lsb_release -cs) stable\" | sudo tee /etc/apt/sources.list.d/docker.list\n\n# 3. Install Engine\nsudo apt-get update\nsudo apt-get install docker-ce docker-ce-cli containerd.io docker-compose-plugin -y\n\n# 4. Fix Port 53 conflict\nsudo systemctl stop systemd-resolved\nsudo systemctl disable systemd-resolved",
      "autoResize": true,
      "lineHeight": 1.25
    },
