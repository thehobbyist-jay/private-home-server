      "x": -911.6202756999924,
      "y": -228.2726023259678,
      "width": 164.3541717529297,
      "height": 113.75,
      "text": "Pi-hole Container\n\n- Port 53 (DNS)\n- Port 8080 (UI)\n\nBlocks network-wide ads\nand local trackers.",
      "fontSize": 13,
      "fontFamily": 8,
      "color": "#ffffff",
      "version": 8,
