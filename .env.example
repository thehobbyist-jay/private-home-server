# Example environment file for linux-server
# Copy this to .env and adjust the values. Do NOT commit your real .env with secrets.
# Generate strong passwords: head -c 32 /dev/urandom | base64

# -------------------------------------------------------------------
# General
# -------------------------------------------------------------------
TIMEZONE=America/New_York

# -------------------------------------------------------------------
# Paths — adjust to match your host filesystem
# -------------------------------------------------------------------
DOCKER_VOLUMES_ROOT=/home/docker-volumes
VSCODE_WORKSPACE=/home/docker-volumes/vscode

# Media / external storage
JELLYFIN_MEDIA_DIR=/home/docker-volumes/jellyfin/media
NEXTCLOUD_DATA_DIR=/home/docker-volumes/nextcloud/data

# Immich storage paths
UPLOAD_LOCATION=/home/docker-volumes/immich
IMMICH_MODEL_CACHE=/home/docker-volumes/immich/model-cache

# Immich database
DB_DATA_LOCATION=/home/docker-volumes/immich/postgres

# -------------------------------------------------------------------
# Network — adjust IPs and interface to match your LAN
# -------------------------------------------------------------------
SERVER_IP=10.10.2.102
PIHOLE_IP=10.10.2.103
BASE_DOMAIN=homepi.local
MACVLAN_PARENT=eno2
MACVLAN_SUBNET=10.10.2.0/24
MACVLAN_GATEWAY=10.10.2.1

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# VSCode direct access host port
VSCODE_HOST_PORT=9002

# Portainer direct access host port
PORTAINER_HOST_PORT=9000

# Jellyfin host port (default 8096)
JELLYFIN_PORT=8096

# -------------------------------------------------------------------
# Image versions (pin for reproducibility)
# -------------------------------------------------------------------
VSCODE_IMAGE=ghcr.io/coder/code-server:latest
NGINX_IMAGE=nginx:1.27-alpine
PIHOLE_IMAGE=pihole/pihole:2025.04.0
DASHY_IMAGE=lissy93/dashy:latest
DOCKERPROXY_IMAGE=tecnativa/docker-socket-proxy:0.3.0
PORTAINER_IMAGE=portainer/portainer-ce:lts
GLANCES_IMAGE=nicolargo/glances:4.3.0.8-full
MYSQL_IMAGE=mysql:8.0
NEXTCLOUD_IMAGE=nextcloud:30
JELLYFIN_IMAGE=jellyfin/jellyfin:10.10.7
QBITTORRENT_IMAGE=linuxserver/qbittorrent:5.1.0
FILEBROWSER_IMAGE=filebrowser/filebrowser:v2

# Immich version
IMMICH_VERSION=v1.132.3

# Access stack images
TAILSCALE_IMAGE=tailscale/tailscale:latest
TWINGATE_IMAGE=twingate/connector:1

# -------------------------------------------------------------------
# Secrets — change these before exposing services to your network
# -------------------------------------------------------------------

# Web UI passwords
VSCODE_PASSWORD=homelab123

# Database passwords
DB_PASSWORD=immich_db_pass
DB_USERNAME=immich
DB_DATABASE_NAME=immich
MYSQL_ROOT_PASSWORD=mysql_root_pass
NEXTCLOUD_DB_PASSWORD=nextcloud_db_pass

# Nextcloud
NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.homepi.local

# -------------------------------------------------------------------
# Access stack secrets (only needed if using remote access)
# -------------------------------------------------------------------

# Tailscale
TS_AUTH_KEY=CHANGE_ME_TAILSCALE_AUTHKEY

# Twingate
TWINGATE_NETWORK=your-network
TWINGATE_ACCESS_TOKEN=CHANGE_ME_TWINGATE_ACCESS_TOKEN
TWINGATE_REFRESH_TOKEN=CHANGE_ME_TWINGATE_REFRESH_TOKEN
TWINGATE_LABEL_HOSTNAME=home-server
